# Sao chép file này thành .env cho máy cục bộ. Không commit file .env.
# Chỉ điền secret tại máy/deployment tương ứng; không gửi secret qua issue hoặc PR.

APP_ENV=development
# Frontend/local legacy port. Backend uses API_PORT below.
APP_PORT=3000

# Backend FastAPI runtime. `fixture` is development-only and must never run in production.
API_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_INTAKE_CHARS=500
MAX_BODY_BYTES=65536
PROCEDURE_DATA_MODE=fixture
RAG_MODE=disabled
LLM_MODE=disabled
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Cấu hình AI tùy kiến trúc đã chốt (D-011). Không ghi key thật ở đây.
# Để trống AI_API_KEY (hoặc LLM_MODE=disabled ở trên) -> LLMGateway fallback
# deterministic, không gọi model nào (an toàn offline/fail-closed).
# Muốn bật giải thích lỗi qua LLM: set LLM_MODE=gateway rồi điền các dòng dưới.
# Khuyến nghị cho demo: OpenAI gpt-4o-mini (đã là default khi để trống,
# JSON mode ổn định, không cần AI_BASE_URL). Không có free credit, nhưng chi
# phí cho khối lượng demo là không đáng kể.
# Thay thế free-quota: Alibaba DashScope, model qwen-flash, nhưng cần set
# enable_thinking=False qua extra_body trong gateway.py mới dùng được
# response_format=json_object (Qwen3 mặc định có thể ở thinking mode).
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_API_KEY=
AI_BASE_URL=

# Tích hợp tùy chọn; để trống nếu dự án không sử dụng.
DATABASE_URL=
SENTRY_DSN=
